<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy 8 Months ❤️</title>

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:linear-gradient(to bottom,#ffd6e7,#fff);
    text-align:center;
    color:#333;
    overflow-x:hidden;
}

/* HEADER */
header{
    padding:60px 20px;
}

h1{
    color:#ff4d88;
    font-size:45px;
}

/* IMAGE */
img{
    width:220px;
    max-width:90%;
    border-radius:20px;
    box-shadow:0 5px 15px rgba(0,0,0,.2);
}

/* BUTTON */
button{
    background:#ff4d88;
    color:white;
    border:none;
    padding:15px 30px;
    font-size:18px;
    border-radius:30px;
    cursor:pointer;
}

button:hover{
    background:#ff2d73;
}

/* LETTER */
#letter{
    display:none;
    max-width:700px;
    margin:auto;
    font-size:20px;
    line-height:1.8;
    padding:20px;
    white-space:pre-line;
}

/* FOOTER */
footer{
    padding:30px;
    color:#666;
}

/* 💖 HEARTS */
.heart{
    position:fixed;
    top:-10px;
    color:#ff4d88;
    font-size:20px;
    animation:fall linear infinite;
    z-index:9999;
}

@keyframes fall{
    0%{transform:translateY(-10vh) translateX(0);opacity:1;}
    100%{transform:translateY(110vh) translateX(50px);opacity:0;}
}

/* hidden music */
iframe{
    display:none;
}
</style>
</head>

<body>

<header>
<h1>Happy 8 Months, Love ❤️</h1>

<img src="joy.jpg" alt="Love Photo">

<p>"Every love story is beautiful, but ours is my favorite."</p>

<button onclick="showLetter()">Open My Letter 💌</button>
</header>

<section id="letter"></section>

<section>
<h2>Reasons I Love You ❤️</h2>

<p>😊 Your smile</p>
<p>🤍 Your kindness</p>
<p>😂 The way you make me laugh</p>
<p>🌸 You make me feel at home</p>
<p>💖 Because you're YOU</p>
</section>

<footer>
Made with all my love ❤️
</footer>

<!-- 🎵 MUSIC -->
<iframe 
    width="0" height="0"
    src="https://www.youtube.com/embed/c4BLVznuWnU?autoplay=1&loop=1&playlist=c4BLVznuWnU"
    allow="autoplay">
</iframe>

<script>
const fullText = `To My Love ❤️

Hi Love,

Happy 8 Monthsary!

Thank you for choosing me every single day.
Thank you for loving me even when I'm not at my best.

These past eight months have been filled with laughter, adventures, and unforgettable memories.

I know we aren't perfect, but I promise to keep choosing you, supporting you, and loving you through every season of life.

You are my favorite person, my safe place, and my greatest blessing.

I can't wait to create more memories, celebrate more anniversaries, and grow old with you.

I love you more than words can ever express.

Forever yours,
❤️ JOY ❤️`;

function showLetter(){
    const letter = document.getElementById("letter");
    letter.style.display = "block";
    letter.innerHTML = "";
    
    let i = 0;

    function typeWriter(){
        if(i < fullText.length){
            letter.innerHTML += fullText.charAt(i);
            i++;
            setTimeout(typeWriter, 30); // speed of typing
        }
    }

    typeWriter();
    document.getElementById("letter").scrollIntoView({behavior:"smooth"});
}

/* 💖 HEARTS */
function createHeart(){
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "❤️";

    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = (3 + Math.random() * 5) + "s";
    heart.style.fontSize = (15 + Math.random() * 25) + "px";

    document.body.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 8000);
}

setInterval(createHeart, 300);
</script>

</body>
</html>
